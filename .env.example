# API runtime
API_PORT=4000
API_HOST=0.0.0.0
API_BASE_PATH=/api/v1
API_AUTH_SECRET=replace-with-a-local-random-secret

# Database connection fallback order used by backend:
#   1) DATABASE_URL
#   2) DB_URL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Local Supabase integration values
ANON_KEY=replace-with-output-from-supabase-status
API_URL=http://127.0.0.1:54321
FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1
GRAPHQL_URL=http://127.0.0.1:54321/graphql/v1
INBUCKET_URL=http://127.0.0.1:54324
JWT_SECRET=replace-with-output-from-supabase-status
MAILPIT_URL=http://127.0.0.1:54324
MCP_URL=http://127.0.0.1:54321/mcp
PUBLISHABLE_KEY=replace-with-local-supabase-publishable-key
REST_URL=http://127.0.0.1:54321/rest/v1
S3_PROTOCOL_ACCESS_KEY_ID=replace-with-local-s3-access-key-id
S3_PROTOCOL_ACCESS_KEY_SECRET=replace-with-local-s3-access-key-secret
S3_PROTOCOL_REGION=local
SECRET_KEY=replace-with-local-supabase-secret-key
SERVICE_ROLE_KEY=replace-with-output-from-supabase-status
STORAGE_S3_URL=http://127.0.0.1:54321/storage/v1/s3
STUDIO_URL=http://127.0.0.1:54323

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
